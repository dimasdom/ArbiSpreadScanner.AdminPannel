ClientBin/
~$*
*~
*.dbmdl
*.dbproj.schemaview
*.jfm
*.pfx
*.publishsettings

# SQL Server files
*.mdf
*.ldf
*.ndf

# Microsoft Fakes
FakesAssemblies/

# Node.js
node_modules/
.ntvs_analysis.dat
npm-debug.log*
yarn-debug.log*
yarn-error.log*

# Python
__pycache__/
*.pyc

# MSBuild logs
*.binlog

# Local History / IDE
.localhistory/
.ionide/
.mfractor/
.fake/
.cr/personal

