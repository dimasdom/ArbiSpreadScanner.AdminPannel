{
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning"
    }
  },
  "Serilog": {
    "MinimumLevel": {
      "Default": "Information",
      "Override": {
        "Microsoft": "Warning",
        "Microsoft.AspNetCore": "Warning",
        "Microsoft.Hosting.Lifetime": "Information",
        "System": "Warning"
      }
    },
    "WriteTo": [
      {
        "Name": "Console"
      },
      {
        "Name": "GrafanaLoki",
        "Args": {
          "uri": "http://localhost:3100",
          "labels": [
            { "key": "app", "value": "arbiscanner-admin" },
            { "key": "env", "value": "development" }
          ],
          "propertiesAsLabels": [ "level" ]
        }
      }
    ],
    "Enrich": [ "FromLogContext", "WithMachineName", "WithThreadId" ]
  },
  "Jwt": {
    "Issuer": "ArbiScannerAdminPanel.Dev",
    "Audience": "ArbiScannerAdminPanel.Client.Dev",
    "SigningKey": "REDACTED",
    "AccessTokenExpirationMinutes": 15,
    "RefreshTokenExpirationDays": 7
  },
  "Seed": {
    "Enabled": false,
    "AdminUserName": "",
    "AdminPassword": "",
    "ManagerUserName": "",
    "ManagerPassword": ""
  }
}
